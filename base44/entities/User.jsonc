{
  "name": "User",
  "type": "object",
  "properties": {
    "role": {
      "type": "string",
      "enum": [
        "admin",
        "manager",
        "labor"
      ],
      "default": "labor",
      "description": "User permission level"
    },
    "pto_hours": {
      "type": "number",
      "default": 0,
      "description": "Accumulated PTO hours"
    }
  }
}