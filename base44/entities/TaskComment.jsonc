{
  "name": "TaskComment",
  "type": "object",
  "properties": {
    "task_id": {
      "type": "string",
      "description": "Associated task ID"
    },
    "author_name": {
      "type": "string",
      "description": "Name of comment author"
    },
    "author_email": {
      "type": "string",
      "description": "Email of comment author"
    },
    "content": {
      "type": "string",
      "description": "Comment text"
    },
    "reply_to_id": {
      "type": "string",
      "description": "ID of parent comment if this is a reply"
    },
    "reply_to_author": {
      "type": "string",
      "description": "Name of author being replied to"
    }
  },
  "required": [
    "task_id",
    "author_email",
    "content"
  ]
}